@php
    $coverImage = $publication->getLocalizedData('coverImage');
@endphp

@if (!$coverImage)
    <x-metadata.default
        slug="cover-image"
    >
        <img
            src="{{ $publication->getLocalizedCoverImageUrl($submission->getData('contextId')) }}"
            alt="@if($coverImage){{ $coverImage['altText'] }}@endif"
        >
    </x-metadata.default>
@endif
