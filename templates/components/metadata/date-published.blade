@if ($publication->getData('datePublished'))
    <x-metadata.default
        slug="date-published"
        title="{{
            $publication->getData('versionStage') === APP\publication\enums\VersionStage::VERSION_OF_RECORD
                ? __('submissions.published')
                : __('announcement.posted')
        }}"
    >
        {{ ViewHelper::dateFormat($publication->getData('datePublished'), $dateFormatLong) }}
    </x-metadata.default>
@endif
